{\n  "info": {\n    \"name\": \"MileyMusics API\",\n    \"description\": \"Complete REST API for MileyMusics music streaming platform\",\n    \"schema\": \"https://schema.getpostman.com/json/collection/v2.1.0/collection.json\"\n  },\n  \"item\": [\n    {\n      \"name\": \"Authentication\",\n      \"item\": [\n        {\n          \"name\": \"Register\",\n          \"request\": {\n            \"method\": \"POST\",\n            \"header\": {\n              \"key\": \"Content-Type\",\n              \"value\": \"application/json\"\n            },\n            \"body\": {\n              \"mode\": \"raw\",\n              \"raw\": \"{\\n  \\\"email\\\": \\\"user@example.com\\\",\\n  \\\"password\\\": \\\"password123\\\",\\n  \\\"username\\\": \\\"username\\\",\\n  \\\"full_name\\\": \\\"Full Name\\\"\n}\"\n            },\n            \"url\": {\n              \"raw\": \"{{BASE_URL}}/api/auth/register\",\n              \"host\": [\"{{BASE_URL}}\"],\n              \"path\": [\"api\", \"auth\", \"register\"]\n            }\n          }\n        },\n        {\n          \"name\": \"Login\",\n          \"request\": {\n            \"method\": \"POST\",\n            \"header\": {\n              \"key\": \"Content-Type\",\n              \"value\": \"application/json\"\n            },\n            \"body\": {\n              \"mode\": \"raw\",\n              \"raw\": \"{\\n  \\\"email\\\": \\\"user@example.com\\\",\\n  \\\"password\\\": \\\"password123\\\"\n}\"\n            },\n            \"url\": {\n              \"raw\": \"{{BASE_URL}}/api/auth/login\",\n              \"host\": [\"{{BASE_URL}}\"],\n              \"path\": [\"api\", \"auth\", \"login\"]\n            }\n          }\n        },\n        {\n          \"name\": \"Refresh Token\",\n          \"request\": {\n            \"method\": \"POST\",\n            \"header\": {\n              \"key\": \"Content-Type\",\n              \"value\": \"application/json\"\n            },\n            \"body\": {\n              \"mode\": \"raw\",\n              \"raw\": \"{\\n  \\\"refresh_token\\\": \\\"your_refresh_token\\\"\n}\"\n            },\n            \"url\": {\n              \"raw\": \"{{BASE_URL}}/api/auth/refresh\",\n              \"host\": [\"{{BASE_URL}}\"],\n              \"path\": [\"api\", \"auth\", \"refresh\"]\n            }\n          }\n        }\n      ]\n    },\n    {\n      \"name\": \"Songs\",\n      \"item\": [\n        {\n          \"name\": \"Get All Songs\",\n          \"request\": {\n            \"method\": \"GET\",\n            \"header\": {\n              \"key\": \"Authorization\",\n              \"value\": \"Bearer {{ACCESS_TOKEN}}\"\n            },\n            \"url\": {\n              \"raw\": \"{{BASE_URL}}/api/songs?limit=20&offset=0\",\n              \"host\": [\"{{BASE_URL}}\"],\n              \"path\": [\"api\", \"songs\"],\n              \"query\": [\n                {\n                  \"key\": \"limit\",\n                  \"value\": \"20\"\n                },\n                {\n                  \"key\": \"offset\",\n                  \"value\": \"0\"\n                }\n              ]\n            }\n          }\n        },\n        {\n          \"name\": \"Get Song by ID\",\n          \"request\": {\n            \"method\": \"GET\",\n            \"header\": {\n              \"key\": \"Authorization\",\n              \"value\": \"Bearer {{ACCESS_TOKEN}}\"\n            },\n            \"url\": {\n              \"raw\": \"{{BASE_URL}}/api/songs/:id\",\n              \"host\": [\"{{BASE_URL}}\"],\n              \"path\": [\"api\", \"songs\", \":id\"]\n            }\n          }\n        },\n        {\n          \"name\": \"Create Song\",\n          \"request\": {\n            \"method\": \"POST\",\n            \"header\": {\n              \"key\": \"Content-Type\",\n              \"value\": \"application/json\",\n              \"key\": \"Authorization\",\n              \"value\": \"Bearer {{ACCESS_TOKEN}}\"\n            },\n            \"body\": {\n              \"mode\": \"raw\",\n              \"raw\": \"{\\n  \\\"title\\\": \\\"Song Title\\\",\\n  \\\"description\\\": \\\"Song Description\\\",\\n  \\\"fileUrl\\\": \\\"https://...\\\",\\n  \\\"genre\\\": \\\"pop\\\",\\n  \\\"mood\\\": \\\"upbeat\\\"\n}\"\n            },\n            \"url\": {\n              \"raw\": \"{{BASE_URL}}/api/songs\",\n              \"host\": [\"{{BASE_URL}}\"],\n              \"path\": [\"api\", \"songs\"]\n            }\n          }\n        },\n        {\n          \"name\": \"Like Song\",\n          \"request\": {\n            \"method\": \"POST\",\n            \"header\": {\n              \"key\": \"Authorization\",\n              \"value\": \"Bearer {{ACCESS_TOKEN}}\"\n            },\n            \"url\": {\n              \"raw\": \"{{BASE_URL}}/api/songs/:id/like\",\n              \"host\": [\"{{BASE_URL}}\"],\n              \"path\": [\"api\", \"songs\", \":id\", \"like\"]\n            }\n          }\n        },\n        {\n          \"name\": \"Unlike Song\",\n          \"request\": {\n            \"method\": \"DELETE\",\n            \"header\": {\n              \"key\": \"Authorization\",\n              \"value\": \"Bearer {{ACCESS_TOKEN}}\"\n            },\n            \"url\": {\n              \"raw\": \"{{BASE_URL}}/api/songs/:id/like\",\n              \"host\": [\"{{BASE_URL}}\"],\n              \"path\": [\"api\", \"songs\", \":id\", \"like\"]\n            }\n          }\n        },\n        {\n          \"name\": \"Record Play\",\n          \"request\": {\n            \"method\": \"POST\",\n            \"header\": {\n              \"key\": \"Authorization\",\n              \"value\": \"Bearer {{ACCESS_TOKEN}}\"\n            },\n            \"url\": {\n              \"raw\": \"{{BASE_URL}}/api/songs/:id/play\",\n              \"host\": [\"{{BASE_URL}}\"],\n              \"path\": [\"api\", \"songs\", \":id\", \"play\"]\n            }\n          }\n        }\n      ]\n    },\n    {\n      \"name\": \"Playlists\",\n      \"item\": [\n        {\n          \"name\": \"Get User Playlists\",\n          \"request\": {\n            \"method\": \"GET\",\n            \"header\": {\n              \"key\": \"Authorization\",\n              \"value\": \"Bearer {{ACCESS_TOKEN}}\"\n            },\n            \"url\": {\n              \"raw\": \"{{BASE_URL}}/api/playlists\",\n              \"host\": [\"{{BASE_URL}}\"],\n              \"path\": [\"api\", \"playlists\"]\n            }\n          }\n        },\n        {\n          \"name\": \"Create Playlist\",\n          \"request\": {\n            \"method\": \"POST\",\n            \"header\": {\n              \"key\": \"Content-Type\",\n              \"value\": \"application/json\",\n              \"key\": \"Authorization\",\n              \"value\": \"Bearer {{ACCESS_TOKEN}}\"\n            },\n            \"body\": {\n              \"mode\": \"raw\",\n              \"raw\": \"{\\n  \\\"title\\\": \\\"My Playlist\\\",\\n  \\\"description\\\": \\\"Description\\\",\\n  \\\"is_public\\\": false\n}\"\n            },\n            \"url\": {\n              \"raw\": \"{{BASE_URL}}/api/playlists\",\n              \"host\": [\"{{BASE_URL}}\"],\n              \"path\": [\"api\", \"playlists\"]\n            }\n          }\n        },\n        {\n          \"name\": \"Add Song to Playlist\",\n          \"request\": {\n            \"method\": \"POST\",\n            \"header\": {\n              \"key\": \"Content-Type\",\n              \"value\": \"application/json\",\n              \"key\": \"Authorization\",\n              \"value\": \"Bearer {{ACCESS_TOKEN}}\"\n            },\n            \"body\": {\n              \"mode\": \"raw\",\n              \"raw\": \"{\\n  \\\"song_id\\\": \\\"song-uuid\\\"\n}\"\n            },\n            \"url\": {\n              \"raw\": \"{{BASE_URL}}/api/playlists/:playlistId/songs\",\n              \"host\": [\"{{BASE_URL}}\"],\n              \"path\": [\"api\", \"playlists\", \":playlistId\", \"songs\"]\n            }\n          }\n        }\n      ]\n    },\n    {\n      \"name\": \"Users\",\n      \"item\": [\n        {\n          \"name\": \"Get User Profile\",\n          \"request\": {\n            \"method\": \"GET\",\n            \"header\": {\n              \"key\": \"Authorization\",\n              \"value\": \"Bearer {{ACCESS_TOKEN}}\"\n            },\n            \"url\": {\n              \"raw\": \"{{BASE_URL}}/api/users/:id\",\n              \"host\": [\"{{BASE_URL}}\"],\n              \"path\": [\"api\", \"users\", \":id\"]\n            }\n          }\n        },\n        {\n          \"name\": \"Update Profile\",\n          \"request\": {\n            \"method\": \"PUT\",\n            \"header\": {\n              \"key\": \"Content-Type\",\n              \"value\": \"application/json\",\n              \"key\": \"Authorization\",\n              \"value\": \"Bearer {{ACCESS_TOKEN}}\"\n            },\n            \"body\": {\n              \"mode\": \"raw\",\n              \"raw\": \"{\\n  \\\"full_name\\\": \\\"New Name\\\",\\n  \\\"bio\\\": \\\"My bio\\\",\\n  \\\"avatar_url\\\": \\\"https://...\\\"\n}\"\n            },\n            \"url\": {\n              \"raw\": \"{{BASE_URL}}/api/users/:id\",\n              \"host\": [\"{{BASE_URL}}\"],\n              \"path\": [\"api\", \"users\", \":id\"]\n            }\n          }\n        },\n        {\n          \"name\": \"Follow User\",\n          \"request\": {\n            \"method\": \"POST\",\n            \"header\": {\n              \"key\": \"Authorization\",\n              \"value\": \"Bearer {{ACCESS_TOKEN}}\"\n            },\n            \"url\": {\n              \"raw\": \"{{BASE_URL}}/api/users/:id/follow\",\n              \"host\": [\"{{BASE_URL}}\"],\n              \"path\": [\"api\", \"users\", \":id\", \"follow\"]\n            }\n          }\n        }\n      ]\n    },\n    {\n      \"name\": \"Search\",\n      \"item\": [\n        {\n          \"name\": \"Search\",\n          \"request\": {\n            \"method\": \"GET\",\n            \"header\": {\n              \"key\": \"Authorization\",\n              \"value\": \"Bearer {{ACCESS_TOKEN}}\"\n            },\n            \"url\": {\n              \"raw\": \"{{BASE_URL}}/api/search?q=query&type=all&limit=20\",\n              \"host\": [\"{{BASE_URL}}\"],\n              \"path\": [\"api\", \"search\"],\n              \"query\": [\n                {\n                  \"key\": \"q\",\n                  \"value\": \"query\"\n                },\n                {\n                  \"key\": \"type\",\n                  \"value\": \"all\"\n                },\n                {\n                  \"key\": \"limit\",\n                  \"value\": \"20\"\n                }\n              ]\n            }\n          }\n        }\n      ]\n    }\n  ],\n  \"variable\": [\n    {\n      \"key\": \"BASE_URL\",\n      \"value\": \"http://localhost:5000\"\n    },\n    {\n      \"key\": \"ACCESS_TOKEN\",\n      \"value\": \"\"\n    }\n  ]\n}\n